---
// Row of 5 stars. Defaults to gold; pass color to override.
interface Props {
  count?: number;
  size?: number;
  color?: string;
}
const { count = 5, size = 18, color = 'var(--color-primary-cta)' } = Astro.props;
const stars = Array.from({ length: count });
---
<span class="stars" aria-label={`${count} out of 5 stars`} role="img">
  {stars.map(() => (
    <svg width={size} height={size} viewBox="0 0 24 24" fill={color} aria-hidden="true">
      <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  ))}
</span>

<style>
  .stars { display: inline-flex; gap: 2px; line-height: 0; }
</style>
