---
import Icon from './Icon.astro';
---
<div class="divider">
  <div class="badge"><Icon name="brush" size={26} /></div>
</div>

<style>
  .divider {
    position: relative;
    height: 16px;
    background: var(--color-primary-cta);
  }
  .badge {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--color-dark);
    color: var(--color-primary);
    display: grid;
    place-items: center;
    border: 4px solid #fff;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.18);
  }
</style>
