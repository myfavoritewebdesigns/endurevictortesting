---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import endureLogo from '../assets/images/endure-logo.png';
---
<header class="header">
  <div class="container header-inner">
    <!-- Logo (real Endure Painting brand mark) -->
    <a href="/" class="logo" aria-label="Endure Painting home">
      <Image src={endureLogo} alt="Endure Painting" widths={[140, 280]} loading="eager" />
    </a>

    <nav class="nav" aria-label="Primary">
      <a class="nav-item" href="#"><strong>Residential</strong><small>Painting</small></a>
      <a class="nav-item" href="#"><strong>Commercial</strong><small>Painting</small></a>
      <a class="nav-item" href="#"><strong>HOA</strong><small>Painting</small></a>
      <a class="nav-item solo" href="#service-area"><strong>Service Areas</strong></a>
      <a class="nav-item solo" href="#owner"><strong>About</strong></a>
      <a class="nav-item solo" href="#contact"><strong>Contact Us</strong></a>
    </nav>

    <div class="header-cta">
      <a class="call" href="tel:+15104582120">
        <span class="call-icon"><Icon name="phone" size={18} /></span>
        <span class="call-text">
          <small>Give Us a Call!</small>
          <strong>(510) 458-2120</strong>
        </span>
      </a>
      <a class="btn btn-primary" href="#contact">Get a Quote</a>
    </div>

    <button class="burger" id="burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.08);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 74px;
  }

  /* logo */
  .logo { display: inline-flex; align-items: center; line-height: 0; }
  .logo :global(img) { height: 52px; width: auto; display: block; }

  /* nav */
  .nav { display: flex; align-items: center; gap: 26px; }
  .nav-item { display: flex; flex-direction: column; align-items: center; line-height: 1.05; }
  .nav-item strong { font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem; color: #2b2b2b; }
  .nav-item small { font-size: 0.62rem; color: var(--color-primary); font-weight: 700; letter-spacing: 0.04em; }
  .nav-item.solo { justify-content: center; }
  .nav-item:hover strong { color: var(--color-primary-dark); }

  /* cta cluster */
  .header-cta { display: flex; align-items: center; gap: 16px; }
  .call { display: inline-flex; align-items: center; gap: 9px; }
  .call-icon {
    width: 34px; height: 34px; border-radius: 50%;
    background: var(--color-primary); color: #1a1a1a;
    display: grid; place-items: center;
  }
  .call-text { display: flex; flex-direction: column; line-height: 1.1; }
  .call-text small { font-size: 0.66rem; color: #777; font-weight: 600; }
  .call-text strong { font-family: var(--font-heading); font-size: 1rem; color: var(--color-primary-dark); }

  /* hamburger (mobile) */
  .burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
  .burger span { width: 26px; height: 3px; background: #2b2b2b; border-radius: 2px; }

  @media (max-width: 1080px) {
    .call-text small { display: none; }
  }
  @media (max-width: 960px) {
    .nav, .header-cta { display: none; }
    .burger { display: flex; }
    .nav.open {
      display: flex; position: absolute; top: 74px; left: 0; right: 0;
      flex-direction: column; align-items: flex-start; gap: 14px;
      background: #fff; padding: 20px 24px; box-shadow: 0 12px 20px rgba(0,0,0,.1);
    }
    .header-cta.open {
      display: flex; position: absolute; top: 100%; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 12px;
      background: #fff; padding: 0 24px 20px;
    }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const nav = document.querySelector('.nav');
  const cta = document.querySelector('.header-cta');
  burger?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    cta?.classList.toggle('open');
  });
</script>
